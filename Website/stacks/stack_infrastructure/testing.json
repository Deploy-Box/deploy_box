[    
    {
        "resource_type": "deployboxrm_edge",
        "subdomain": "testing",
        "root_base_url": "${azurerm_container_app.azurerm_container_app_0.ingress.fqdn}",
        "api_base_url": "https://www.example.com/",
        "index": 0
    },
    {
        "resource_type": "azurerm_container_app",
        "index": 0,
        "container_app_environment_id": "${azurerm_container_app_environment.azurerm_container_app_environment_0.azurerm_id}",
        "resource_group_name": "${azurerm_resource_group.azurerm_resource_group_0.azurerm_name}",
        "template_container_name": "myapp",
        "template_container_image": "nginx:latest",
        "template_container_env": [
            {
                "name": "WORKOS_API_KEY",
                "value": "${deployboxrm_workos_integration.deployboxrm_workos_integration_0.api_key}"
            },
            {
                "name": "WORKOS_CLIENT_ID",
                "value": "${deployboxrm_workos_integration.deployboxrm_workos_integration_0.client_id}"
            },
            {
                "name": "WORKOS_REDIRECT_URI",
                "value": "${deployboxrm_workos_integration.deployboxrm_workos_integration_0.redirect_uri}"
            },
                        {
                "name": "POSTGRES_CONNECTION_STRING",
                "value": "${thenilerm_database.thenilerm_database_0.db_host}"
            }
        ]
    },
]